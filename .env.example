# Copy to .env and fill in real values before running docker compose.
# NEVER commit .env — it is listed in .gitignore.
# Generate JWT_SECRET with: openssl rand -hex 32

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=changeme
POSTGRES_DB=kanban
POSTGRES_USER=kanban

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-32-char-string
JWT_EXPIRY_MS=3600000

# ── Frontend build-time URLs ──────────────────────────────────────────────────
# Replace your-ec2-ip with the public IP or domain of your EC2 instance.
NEXT_PUBLIC_API_URL=http://your-ec2-ip:8080
NEXT_PUBLIC_WS_URL=http://your-ec2-ip:8080/ws
NEXT_PUBLIC_AGENT_URL=http://your-ec2-ip:8001

# ── Production image references (used by docker-compose.prod.yml) ─────────────
# REGISTRY: your ECR registry URL, e.g. 123456789.dkr.ecr.ap-south-1.amazonaws.com
# VERSION:  the git SHA tag produced by the CI pipeline (e.g. a1b2c3d)
REGISTRY=your-ecr-registry
VERSION=replace-with-git-sha
