# Local env files with secrets — never commit
.env
.env.local
.env.*.local

# Per-developer local permissions (never commit)
.claude/settings.local.json

# Hook runtime logs (generated per session)
.claude/logs/

# Runtime memory — generated per project, not part of the template
.claude/memory/events.jsonl
.claude/memory/kanban.json
.claude/memory/plan.json
.claude/memory/requirements.html
.claude/memory/delivery.html
.claude/memory/architecture/system-design.yaml
.claude/memory/architecture/design_review.html
.claude/memory/security/findings.json
.claude/memory/stories/*/
.claude/memory/bugs/registry.html
.claude/memory/test-reports/*.html
.claude/memory/test-reports/regression-results.json
.claude/memory/decisions/DEC-*.html
.claude/memory/patterns/*.html

# Generated project docs (produced by architect/doc-writer at runtime)
docs/architecture/hld.html
docs/architecture/diagrams/hld.drawio
docs/architecture/flows/
docs/api/*.html
docs/ui/*.html
docs/stories/index.html
docs/adr/
docs/runbooks/

# Regression suite registry (populated at runtime)
tests/regression/suite.json


# Codebase build artifacts and dependencies — never commit
codebase/frontend/node_modules/
codebase/frontend/.next/
codebase/frontend/e2e-report/
codebase/frontend/debug-issues.png
codebase/backend/node_modules/
codebase/backend/dist/
codebase/backend/target/
codebase/backend/build/
codebase/backend/.gradle/
codebase/backend/bin/

# Private keys and certificates — never commit
*.pem
*.key

# Large binaries
*.tar
*.tar.gz
kanban-images.tar

# Runtime output
runs/

# Kanban board state (generated per session)
.claude/memory/stories/kanban.json

# OS / editor noise
.DS_Store
Thumbs.db
*.swp
*.swo
